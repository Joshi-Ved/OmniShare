rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Categories - anyone can read
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if true;
    }

    // Users - read public, write if self
    match /users/{userId} {
      allow read: if true;
      allow write: if true;
    }

    // Listings - anyone can read, auth only to write
    match /listings/{listingId} {
      allow read: if true;
      allow write: if true;
    }

    // Default - authenticated access
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
