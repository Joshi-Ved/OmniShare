# ─────────────────────────────────────────────
#  OmniShare .gitignore
# ─────────────────────────────────────────────

# ── Environment & Secrets (NEVER commit) ─────
.env
.env.local
.env.*.local
.env.production
.env.staging
*.pem
*.key
secrets.json

# ── Python / Django ───────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
.Python
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
venv/
env/
.venv/
.env/
ENV/
env.bak/
venv.bak/
.python-version

# Django specifics
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
media/
staticfiles/
static_collected/

# ── Node / JavaScript ─────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# Build outputs
dist/
build/
.next/
out/
.nuxt/
.cache/
.parcel-cache/

# ── IDEs & Editors ────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
Desktop.ini

# ── OS files ──────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ── Testing ───────────────────────────────────
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
pytestdebug.log

# ── Deployment ────────────────────────────────
*.zip
*.tar.gz
*.tar
Procfile.local
.railway/

# ── Misc ──────────────────────────────────────
*.bak
*.tmp
*.temp
